# 环境配置文件示例
# 复制此文件为 .env 并填入实际配置

# ============================================
# TV 端配置
# ============================================
# TV 端 API 地址（生产环境）
TV_API_HOST=http://your-server-ip:8080

# ============================================
# Manager 后端配置
# ============================================
# 应用配置
APP_NAME=sheet-music-manager
APP_ENV=production
SERVER_PORT=8080
GIN_MODE=release

# 数据库配置
DB_DRIVER=mysql
DATABASE_DSN=username:password@tcp(host:3306)/database?charset=utf8mb4&parseTime=True&loc=Local

# 日志配置
LOG_LEVEL=info

# JWT 密钥（请使用随机字符串）
JWT_SECRET=please-change-this-to-random-string

# 文件上传配置
UPLOAD_DIR=public/uploads
MAX_FILE_SIZE=10485760
